<?xml version="1.0" encoding="utf-8"?>
<!-- Static preview shown in the widget picker (replaces Glance's loading spinner). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/widget_preview_bg"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="68%"
        android:textColor="@color/widget_accent"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Today's habits"
        android:textColor="@color/widget_muted"
        android:textSize="12sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="2 / 3 done"
        android:textColor="@color/widget_text"
        android:textSize="12sp" />
</LinearLayout>
